        "certifications": { "type": "array", "items": { "type": "string" }, "description": "e.g., HACCP, ISO 22000" },
        "aircraftTypes": { "type": "array", "items": { "type": "string" }, "description": "Supported aircraft types for catering" },
        "contactEmail": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" },
        "headquarters": { "type": "string" },
        "rating": { "type": "number" },
        "ai_verified": { "type": "boolean" },
        "cateringFee": { "type": "number", "description": "Standard catering fee per flight" },
        "last_updated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "airports"]
    },
    "FuelProvider": {
      "title": "FuelProvider",
      "description": "Aviation fuel service providers and FBO fueling services.",
