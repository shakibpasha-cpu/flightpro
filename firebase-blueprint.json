      "properties": {
        "name": { "type": "string" },
        "airports": { "type": "array", "items": { "type": "string" }, "description": "ICAO codes of airports where services are provided" },
        "capabilities": { "type": "array", "items": { "type": "string" }, "description": "e.g., A-Check, B-Check, Engine Overhaul, Avionics" },
        "certifications": { "type": "array", "items": { "type": "string" }, "description": "e.g., EASA Part 145, FAA Part 145" },
        "aircraftTypes": { "type": "array", "items": { "type": "string" }, "description": "Airplanes supported for maintenance" },
        "contactEmail": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" },
        "headquarters": { "type": "string" },
        "rating": { "type": "number" },
        "ai_verified": { "type": "boolean" },
        "last_updated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "airports"]
    },
    "CateringProvider": {
      "title": "CateringProvider",
      "description": "In-flight catering service providers at airports.",
