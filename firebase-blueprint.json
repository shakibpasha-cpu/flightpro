      "properties": {
        "name": { "type": "string" },
        "airports": { "type": "array", "items": { "type": "string" }, "description": "ICAO codes of airports where services are provided" },
        "fuelTypes": { "type": "array", "items": { "type": "string" }, "description": "e.g., Jet A-1, SAF, Avgas 100LL" },
        "services": { "type": "array", "items": { "type": "string" }, "description": "e.g., Into-plane fueling, Defueling" },
        "contactEmail": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" },
        "headquarters": { "type": "string" },
        "rating": { "type": "number" },
        "ai_verified": { "type": "boolean" },
        "providerType": { "type": "string", "enum": ["Fuel Company", "FBO", "Airport Authority"] },
        "last_updated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "airports"]
    },
