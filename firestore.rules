rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "shakibpasha@gmail.com" || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

function isValidOperatorMaster(data) {
      return data.operator_name is string && data.operator_name.size() > 0 && data.operator_name.size() < 100 &&
             data.country is string && data.country.size() > 0 &&
             (!('region' in data) || data.region is string) &&
             (!('status' in data) || data.status in ['Active', 'Suspended', 'Pending']) &&
             (!('license_type' in data) || data.license_type in ['AOC', 'RPT', 'BOTH']) &&
             (!('aoc_number' in data) || data.aoc_number is string) &&
             (!('lastContacted' in data) || data.lastContacted is string) &&
             (!('operation_type' in data) || data.operation_type in ['Scheduled', 'Charter', 'Cargo', 'Helicopter']);
    }

    function isValidOperator(data) {
      return data.operator_name is string && data.operator_name.size() > 0 &&
             data.contact_email is string &&
             (!('status' in data) || data.status in ['Active', 'Suspended', 'Pending']) &&
             (!('aoc_number' in data) || data.aoc_number is string) &&
             (!('lastContacted' in data) || data.lastContacted is string) &&
             (!('operation_type' in data) || data.operation_type in ['Scheduled', 'Charter', 'Cargo', 'Helicopter']);
    }

    function isValidAircraftFleet(data) {
      return data.operator_id is string &&
             data.aircraft_type is string &&
             data.quantity is int &&
             (!('aircraft_family' in data) || data.aircraft_family in ['Narrowbody', 'Widebody', 'Freighter', 'Regional', 'Private Jet']);
    }

    function isValidAOCLicense(data) {
      return data.operator_id is string &&
             data.license_type in ['AOC', 'RPT'] &&
             data.status in ['Active', 'Expired', 'Suspended'];
    }

    function isValidAviationAuthority(data) {
      return data.country is string &&
             data.authority_name is string &&
             (!('scraping_type' in data) || data.scraping_type in ['PDF', 'HTML', 'API', 'Navigation']) &&
             (!('last_scraped' in data) || data.last_scraped is string) &&
             (!('aoc_data' in data) || data.aoc_data is list);
    }

    function isValidCrewMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ["Captain", "First Officer", "Flight Engineer", "Cabin Crew", "Loadmaster"] &&
             data.status in ["Active", "On Leave", "Training", "Sick"];
    }

    function isValidDutyLog(data) {
      return data.crewMemberId is string &&
             data.startTime is string &&
             data.endTime is string &&
             data.type in ["Flight", "Standby", "Training", "Positioning"];
    }

    function isValidFlightLog(data) {
      return data.aircraft_listing_id is string &&
             data.departure is string &&
             data.destination is string &&
             data.date is string &&
             data.duration_hours is number;
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.title is string && data.title.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.type in ["info", "warning", "critical", "success"] &&
             data.status in ["unread", "read", "dismissed"] &&
             data.createdAt is string;
    }

    function isValidPermitProvider(data) {
      return data.name is string && data.name.size() > 0 &&
             (!('contactEmail' in data) || data.contactEmail is string) &&
             (!('website' in data) || data.website is string) &&
             (!('regions' in data) || data.regions is list);
    }

    // Global Databases - Publicly readable, admin only write
    match /airports/{airportId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    match /aircraft/{aircraftId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /firs/{firId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /handlingAgents/{agentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /crew/{crewId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /pricingRules/{ruleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /routes/{routeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ACMI Database - Publicly readable, admin only write
    match /aircraft_master/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /operators/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidOperator(request.resource.data);
      allow update: if isAdmin() && isValidOperator(request.resource.data);
      allow delete: if isAdmin();
    }

    match /operators_master/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidOperatorMaster(request.resource.data);
      allow update: if isAdmin() && isValidOperatorMaster(request.resource.data);
      allow delete: if isAdmin();
    }

    match /aircraft_fleet/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidAircraftFleet(request.resource.data);
      allow update: if isAdmin() && isValidAircraftFleet(request.resource.data);
      allow delete: if isAdmin();
    }

    match /aoc_licenses/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidAOCLicense(request.resource.data);
      allow update: if isAdmin() && isValidAOCLicense(request.resource.data);
      allow delete: if isAdmin();
    }

    match /aviation_authorities/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidAviationAuthority(request.resource.data);
      allow update: if isAdmin() && isValidAviationAuthority(request.resource.data);
      allow delete: if isAdmin();
    }

    match /aircraft_listings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /availability/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pricing_adjustments/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fuel_prices/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fir_charges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /airport_charges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /crew_costs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /insurance_rules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ai_predictions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /empty_legs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quote_history/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /aircraft_rates/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /handling_agents/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /crew_members/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidCrewMember(request.resource.data);
      allow update: if isAdmin() && isValidCrewMember(request.resource.data);
      allow delete: if isAdmin();
    }

    match /duty_logs/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidDutyLog(request.resource.data);
      allow update: if isAuthenticated() && isValidDutyLog(request.resource.data);
      allow delete: if isAdmin();
    }

    match /automation_tasks/{taskId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /flight_plans/{planId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /route_templates/{templateId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /flight_logs/{logId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /mro_providers/{document=**} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /catering_providers/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fuel_providers/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /permit_providers/{document=**} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /availability_intelligence/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /operator_enrichment/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /plan_analysis_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /fir_data/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /route_details_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /optimized_route_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /suggested_aircraft_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /risk_assessment_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /leg_fir_analysis_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /airport_search_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /empty_legs_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /availability_intelligence/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
